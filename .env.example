# Polymarket Trader Environment Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
DB_USER=trader
DB_PASSWORD=your_secure_password_here

# News API Keys
NEWSAPI_KEY=your_newsapi_key_here

# Telegram Bot Configuration
# Get bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Get chat ID by sending /start to your bot and checking:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id

# Discord Webhook (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Dashboard Authentication (optional)
DASHBOARD_USER=admin
DASHBOARD_PASS=your_dashboard_password

# Grafana (optional, for monitoring profile)
GRAFANA_USER=admin
GRAFANA_PASS=your_grafana_password

# Trading Configuration
# Set to 'true' for live trading (requires careful setup)
ENABLE_LIVE_TRADING=false
POLYMARKET_PRIVATE_KEY=your_private_key_here_if_live_trading
